# ════════════════════════════════════════════
# Environment Variables — Face Mask & Emotion Detection
# Copy to .env before running the project
# NEVER commit this file with real secrets!
# ════════════════════════════════════════════

# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# SQL Server
SQL_SERVER_HOST=localhost
SQL_SERVER_PORT=1433
SQL_SERVER_DB=FaceMaskEmotionDB
SQL_SERVER_USER=sa
SQL_SERVER_PASS=YourStrong!Pass123

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=face_mask_emotion

# Redis
REDIS_URL=redis://localhost:6379

# ML models path (absolute or relative to backend dir)
ML_MODELS_DIR=../ml/models
